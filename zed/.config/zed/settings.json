{
  "agent": {
    "default_model": {
      "provider": "ollama",
      "model": "deepseek-coder-v2:16b",
      "enable_thinking": false
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "proxy": "",
  "icon_theme": "Catppuccin Frappé",
  "cli_default_open_behavior": "existing_window",
  "disable_ai": false,
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Dracula",
  },
}
